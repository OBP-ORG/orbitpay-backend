{
  "name": "backend",
  "version": "1.0.0",
  "description": "OrbitPay analytics API and indexer services",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev:api": "ts-node src/index.ts",
    "dev:indexer": "ts-node src/indexer.ts",
    "start:api": "node dist/index.js",
    "start:indexer": "node dist/indexer.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:unit": "node -r ts-node/register/transpile-only --test src/reconciliation/canonical.test.ts src/reconciliation/compare.test.ts src/__tests__/decimal-precision.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}

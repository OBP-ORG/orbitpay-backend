PORT=3001
INDEXER_PORT=3002

DATABASE_URL=postgresql://orbitpay:orbitpay@localhost:5432/orbitpay?schema=public
REDIS_URL=redis://localhost:6379

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKOFF_BASE_SECONDS=60

INDEXER_POLL_INTERVAL_MS=5000

# Auth
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_TTL_SECONDS=3600

# Proxy topology (set to number of trusted proxies, or 'loopback'/'linklocal'/'uniquelocal')
TRUST_PROXY=loopback

# Timeouts
DB_QUERY_TIMEOUT_MS=5000
REDIS_SOCKET_TIMEOUT_MS=3000

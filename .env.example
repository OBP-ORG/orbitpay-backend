PORT=3001
INDEXER_PORT=3002

DATABASE_URL=postgresql://orbitpay:orbitpay@localhost:5432/orbitpay?schema=public
REDIS_URL=redis://localhost:6379

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKOFF_BASE_SECONDS=60

# Stellar / Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract IDs (populate after deployment)
TREASURY_CONTRACT_ID=
PAYROLL_STREAM_CONTRACT_ID=
VESTING_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=

# Indexer
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_BATCH_SIZE=100
INDEXER_START_LEDGER=0
INDEXER_MAX_RETRIES=5
INDEXER_RETRY_BASE_MS=2000
INDEXER_METRICS_PORT=9090

# Auth
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_TTL_SECONDS=3600

# Proxy topology (set to number of trusted proxies, or 'loopback'/'linklocal'/'uniquelocal')
TRUST_PROXY=loopback

# Timeouts
DB_QUERY_TIMEOUT_MS=5000
REDIS_SOCKET_TIMEOUT_MS=3000
